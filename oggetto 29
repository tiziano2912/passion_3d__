<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Prototipazione</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <header>
    <h1>Prototipazione 3D</h1>
    <p>Creiamo prototipi unici e personalizzati.</p>
  </header>

  <main>
    <section id="progetti">
      <h2>Progetti Realizzati</h2>
      <p>Alcuni dei nostri lavori recenti:</p>
      <div class="gallery">
        <div class="project">Progetto 1</div>
        <div class="project">Progetto 2</div>
        <div class="project">Progetto 3</div>
      </div>
    </section>

    <section id="preventivi">
      <h2>Richiedi un Preventivo</h2>
      <form action="https://formspree.io/f/tuo-form-id" method="POST">
        <label for="nome">Nome:</label>
        <input type="text" id="nome" name="nome" required>

        <label for="email">Email:</label>
        <input type="email" id="email" name="email" required>

        <label for="messaggio">Messaggio:</label>
        <textarea id="messaggio" name="messaggio" rows="4" required></textarea>

        <button type="submit">Invia</button>
      </form>
    </section>
  </main>

  <footer>
    <p>&copy; 2024 Prototipazione 3D - Tutti i diritti riservati</p>
  </footer>
</body>
</html>
